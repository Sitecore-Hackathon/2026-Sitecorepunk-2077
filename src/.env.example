# Anthropic API key for code generation (server-side only)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Override the default model (defaults to claude-opus-6-4)
# ANTHROPIC_MODEL=claude-opus-4-6

# Vercel API token for deployment (create at https://vercel.com/account/tokens)
VERCEL_TOKEN=your-vercel-token-here

# Optional: Custom Vercel project name prefix
# VERCEL_PROJECT_NAME=my-custom-prefix

# Optional: Vercel team ID for deployments under a team (required for disabling deployment protection when using team scope)
# VERCEL_TEAM_ID=team_xxx

# Optional: Disable auto-redeploy after chat refinement (default: true)
# VIBECORE_AUTO_REDEPLOY=false

# Optional: Keep Vercel deployment protection enabled (default: true = disable protection for public URLs)
# VIBECORE_DISABLE_VERCEL_PROTECTION=false
